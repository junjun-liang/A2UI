{
  "name": "widget-builder",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "sync-gallery": "node scripts/sync-gallery.mjs",
    "dev": "node scripts/sync-gallery.mjs && next dev --turbopack --port 3001",
    "build": "wireit",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "wireit",
    "test:watch": "vitest",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "clean": "wireit",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@a2ui/react": "workspace:*",
    "@a2ui/web_core": "workspace:*",
    "@copilotkit/react-core": "^1.59.5",
    "@copilotkit/react-ui": "^1.59.5",
    "@copilotkit/runtime": "^1.59.5",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-alert-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.11.10",
    "localforage": "^1.10.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^3.0.6",
    "shiki": "^4.2.0",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.9",
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-only-warn": "^1.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-turbo": "^2.9.18",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8",
    "wireit": "^0.15.0-pre.2",
    "wrangler": "^4.100.0"
  },
  "wireit": {
    "build": {
      "command": "node scripts/sync-gallery.mjs && next build --webpack",
      "dependencies": [
        "../../renderers/web_core:build",
        "../../renderers/lit:build",
        "../../renderers/react:build"
      ],
      "files": [
        "src/**/*",
        "public/**/*",
        "tsconfig.json",
        "*.config.*"
      ],
      "output": [
        ".next/"
      ]
    },
    "test": {
      "command": "vitest run",
      "dependencies": [
        "build"
      ],
      "files": [
        "src/**/*",
        "tsconfig.json"
      ]
    },
    "clean": {
      "command": "rm -rf .next out dist build .tsbuildinfo .wireit"
    }
  }
}
